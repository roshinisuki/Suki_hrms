model Unit {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobInfos JobInfo[]

  @@map("Unit")
}

// Q1: Drafted as separate table from Level.
model Grade {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobInfos JobInfo[]

  @@map("Grade")
}

// Q1: Drafted as separate table from Grade.
model Level {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  jobInfos JobInfo[]

  @@map("Level")
}

// ─────────────────────────────────────────────────────────────────────────────
// 2. STATUTORY SLAB / RATE TABLES (versioned: effectiveFrom / effectiveTo)
//    effectiveTo IS NULL → currently active version.
//    Overlap prevention: SQL Server AFTER INSERT/UPDATE triggers (Option D).
//    See prisma/triggers/slab_overlap_triggers.sql
// ─────────────────────────────────────────────────────────────────────────────

model TDSSlab {
  id            Int       @id @default(autoincrement())
  code          String    @db.NVarChar(20)
  minSalary     Decimal   @db.Decimal(18, 2)
  maxSalary     Decimal?  @db.Decimal(18, 2) // NULL = no upper limit
  ratePercent   Decimal   @db.Decimal(5, 2)  // e.g. 5.00, 10.00, 20.00
  effectiveFrom DateTime
  effectiveTo   DateTime? // NULL = currently active
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([effectiveFrom, effectiveTo])
  @@index([code])
  @@map("TDSSlab")
}

model ProfessionalTaxSlab {
  id            Int       @id @default(autoincrement())
  code          String    @db.NVarChar(20)
  minSalary     Decimal   @db.Decimal(18, 2)
  maxSalary     Decimal?  @db.Decimal(18, 2) // NULL = no upper limit
  monthlyAmount Decimal   @db.Decimal(18, 2) // fixed monthly PT amount
  effectiveFrom DateTime
  effectiveTo   DateTime? // NULL = currently active
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([effectiveFrom, effectiveTo])
  @@index([code])
  @@map("ProfessionalTaxSlab")
}

// Q2: Drafted as two separate tables (EsiRate, PfRate).
model EsiRate {
  id                       Int       @id @default(autoincrement())
  code                     String    @db.NVarChar(20)
  employeeContributionRate Decimal   @db.Decimal(5, 2)  // e.g. 0.75
  employerContributionRate Decimal   @db.Decimal(5, 2)  // e.g. 3.25
  wageCeilingMonthly       Decimal   @db.Decimal(18, 2) // max monthly wage for ESI applicability
  effectiveFrom            DateTime
  effectiveTo              DateTime? // NULL = currently active
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([effectiveFrom, effectiveTo])
  @@index([code])
  @@map("EsiRate")
}

// Q2: Drafted as two separate tables (EsiRate, PfRate).
model PfRate {
  id                       Int       @id @default(autoincrement())
  code                     String    @db.NVarChar(20)
  employeeContributionRate Decimal   @db.Decimal(5, 2)  // e.g. 12.00
  employerContributionRate Decimal   @db.Decimal(5, 2)  // e.g. 12.00 (or 3.67 + 8.33 EPS)
  pensionContributionRate  Decimal?  @db.Decimal(5, 2)  // EPS share, e.g. 8.33
  wageCeilingMonthly       Decimal   @db.Decimal(18, 2) // max monthly wage for PF applicability
  effectiveFrom            DateTime
  effectiveTo              DateTime? // NULL = currently active
  isActive                 Boolean   @default(true)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@index([effectiveFrom, effectiveTo])
  @@index([code])
  @@map("PfRate")
}

// ─────────────────────────────────────────────────────────────────────────────
// 3. SHIFT & OVERTIME DEFINITION TABLES
// ─────────────────────────────────────────────────────────────────────────────

model ShiftMaster {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.NVarChar(20)
  name         String    @db.NVarChar(100)
  startTime    String    @db.NVarChar(8)  // "09:00" (HH:mm)
  endTime      String    @db.NVarChar(8)  // "18:00" (HH:mm)
  graceMinutes Int       @default(0)
  description  String?   @db.NVarChar(500)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  shiftPlans ShiftPlan[]
  jobInfos    JobInfo[]

  @@map("ShiftMaster")
}

// Q8: APPROVED shape — named plan + FK to ShiftMaster + optional overrides.
//     TODO BEFORE PHASE 2 (Attendance): spec out exactly which fields an
//     override can touch (startTime, endTime, graceMinutes, breakDuration?).
//     Attendance must not guess at override semantics it wasn't designed against.
model ShiftPlan {
  id            Int       @id @default(autoincrement())
  shiftMasterId Int
  code          String    @unique @db.NVarChar(20)
  name          String    @db.NVarChar(100)
  startTime     String?   @db.NVarChar(8)  // override ShiftMaster if set
  endTime       String?   @db.NVarChar(8)  // override ShiftMaster if set
  description   String?   @db.NVarChar(500)
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  shiftMaster ShiftMaster @relation(fields: [shiftMasterId], references: [id])
  jobInfos    JobInfo[]    @relation("ShiftPlanJobInfos")

  @@index([shiftMasterId])
  @@map("ShiftPlan")
}

// Q9: Drafted as OT rate definition. Confirm shape.
model OTPlan {
  id                     Int       @id @default(autoincrement())
  code                   String    @unique @db.NVarChar(20)
  name                   String    @db.NVarChar(100)
  otRateMultiplier       Decimal   @db.Decimal(5, 2)  // e.g. 1.50, 2.00
  applicableAfterMinutes Int       @default(0)        // OT kicks in after N minutes
  maxOtHoursPerDay       Int?      // NULL = no cap
  description            String?   @db.NVarChar(500)
  isActive               Boolean   @default(true)
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@map("OTPlan")
}

// ─────────────────────────────────────────────────────────────────────────────
// 4. GENERIC DROPDOWN MASTER
// ─────────────────────────────────────────────────────────────────────────────

// Q10: Drafted with category grouping + label/value + sortOrder.
model DropdownMaster {
  id         Int       @id @default(autoincrement())
  category   String    @db.NVarChar(50)  // grouping key, e.g. "gender", "blood_group"
  label      String    @db.NVarChar(100) // display text
  value      String    @db.NVarChar(100) // stored value
  sortOrder  Int       @default(0)
  isActive   Boolean   @default(true)
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([category, value])
  @@index([category])
  @@map("DropdownMaster")
}

// ─────────────────────────────────────────────────────────────────────────────
// 5. LEAVE / LOAN / ASSET — DEFINITION TABLES (no logic)
// ─────────────────────────────────────────────────────────────────────────────

// Q11: Drafted with minimal definition fields. Confirm if flags needed.
model LeaveMaster {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("LeaveMaster")
}

model LoanType {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("LoanType")
}

model AssetMaster {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assetAllocations EmployeeAssetAllocation[]

  @@map("AssetMaster")
}

// ─────────────────────────────────────────────────────────────────────────────
// 6. AUTH + RBAC SKELETON
//    (feature/auth-rbac branch — included here so schema is complete)
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]

  @@map("Role")
}

model Permission {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(50) // e.g. "employee.view", "payroll.run"
  module      String    @db.NVarChar(50)         // top-level module, e.g. "employee"
  submodule   String?   @db.NVarChar(50)         // sub-module, e.g. "profile"
  page        String?   @db.NVarChar(50)         // page-level, e.g. "list"
  action      String    @db.NVarChar(20)         // "view" | "create" | "edit" | "delete" | "export"
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]

  @@index([module, submodule, page])
  @@map("Permission")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}

// ─────────────────────────────────────────────────────────────────────────────
// 7. EMPLOYEE MASTER (feature/employee-master-models)
//
//    Employee is the core record. Related data is split into sub-tables
//    (PersonalDetails, JobInfo, SalaryStructure, Dependents, Experience,
//    Education, Documents, ExitInterview) — each FKs back to Employee.
//
//    JobInfo FKs into the already-merged Org structure tables:
//      Department, SubDepartment, Designation, EmployeeType, Category,
//      Grade, Level, Unit, ShiftMaster, ShiftPlan
//
//    Asset allocation is a read-only reference via EmployeeAssetAllocation
//    join table → AssetMaster. No asset data duplicated on Employee.
//
//    OPEN QUESTIONS (Employee Master):
//      E1. Employee code format — auto-generated or manual? Pattern?
//          DRAFTED: manual entry, NVarChar(20), unique.
//      E2. Should Employee have a status enum (active/on-leave/terminated/resigned)?
//          DRAFTED: Yes — status String with NVarChar(20) for flexibility.
//          Future: constrain via DropdownMaster or enum.
//      E3. Multiple JobInfo records (history) or single current record?
//          DRAFTED: Multiple — JobInfo has effectiveFrom/effectiveTo for
//          job history tracking. Only one record with effectiveTo = NULL
//          at a time (current job info).
//      E4. SalaryStructure — single current CTC or versioned history?
//          DRAFTED: Versioned — effectiveFrom/effectiveTo, same pattern
//          as slab tables. Only one active record at a time.
//      E5. Documents — one row per document type or a generic documents table?
//          DRAFTED: One row per document type with typed fields for
//          Aadhaar/PAN/Passport/DL + expiry tracking. Generic document
//          uploads via separate Document table for other files.
//      E6. KPI/JD attachment — separate table or fields on Employee?
//          DRAFTED: Separate EmployeeDocument table with docType =
//          "kpi" | "jd" | "other". Placeholder only — no UI beyond stub.
//      E7. ExitInterview — on Employee or separate?
//          DRAFTED: Separate model, 1:1 with Employee, created on exit.
//      E8. Reporting manager — self-referential FK on Employee?
//          DRAFTED: Yes — reportingManagerId Int? self-FK on Employee.
//      E9. Bank details — on Employee or separate table?
//          DRAFTED: Separate EmployeeBankDetail (1:1) — multiple bank
//          accounts may be needed in future.
// ─────────────────────────────────────────────────────────────────────────────

// E1: Manual code entry for now. Auto-generation pattern TBD.
model Employee {
  id                 Int       @id @default(autoincrement())
  employeeCode       String    @unique @db.NVarChar(20)
  firstName          String    @db.NVarChar(100)
  middleName         String?   @db.NVarChar(100)
  lastName           String    @db.NVarChar(100)
  // E2: Status as flexible string — constrain via DropdownMaster later
  status             String    @default("active") @db.NVarChar(20) // active | on-leave | terminated | resigned
  // E8: Self-referential FK for reporting manager
  reportingManagerId Int?

  isActive           Boolean   @default(true)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Self-referential relation for reporting manager
  // NoAction required to break cyclic cascade through child tables
  reportingManager   Employee?  @relation("EmployeeToManager", fields: [reportingManagerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  directReports      Employee[] @relation("EmployeeToManager")

  // 1:1 relations
  personalDetails    PersonalDetails?
  bankDetail         EmployeeBankDetail?
  exitInterview      ExitInterview?

  // 1:N relations (versioned tables are 1:N, not 1:1)
  jobInfos           JobInfo[]
  salaryStructures   SalaryStructure[]
  dependents         EmployeeDependent[]
  experiences        EmployeeExperience[]
  educations         EmployeeEducation[]
  documents          EmployeeDocument[]
  assetAllocations   EmployeeAssetAllocation[]

  @@index([reportingManagerId])
  @@index([status])
  @@map("Employee")
}

// Personal details — 1:1 with Employee
model PersonalDetails {
  id             Int       @id @default(autoincrement())
  employeeId     Int       @unique
  dateOfBirth    DateTime?
  gender         String?   @db.NVarChar(20)   // via DropdownMaster
  bloodGroup     String?   @db.NVarChar(10)   // via DropdownMaster
  maritalStatus  String?   @db.NVarChar(20)   // via DropdownMaster
  nationality    String?   @db.NVarChar(50)
  religion       String?   @db.NVarChar(50)
  category       String?   @db.NVarChar(50)   // via DropdownMaster (general category)
  physicallyChallenged Boolean @default(false)
  // Contact
  personalEmail  String?   @db.NVarChar(100)
  mobileNumber   String?   @db.NVarChar(20)
  alternatePhone String?   @db.NVarChar(20)
  // Address
  presentAddress String?   @db.NVarChar(500)
  permanentAddress String? @db.NVarChar(500)
  // Emergency contact
  emergencyContactName  String? @db.NVarChar(100)
  emergencyContactPhone String? @db.NVarChar(20)
  emergencyContactRelation String? @db.NVarChar(50)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee       Employee  @relation(fields: [employeeId], references: [id])

  @@map("PersonalDetails")
}

// E3: JobInfo is versioned — effectiveFrom/effectiveTo for job history.
//     Only one record with effectiveTo = NULL = current job info.
//     FKs into existing Org structure tables — no redefinition.
model JobInfo {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  // FKs into merged Org tables
  departmentId    Int
  subDepartmentId Int?
  designationId   Int
  employeeTypeId  Int
  categoryId      Int?
  gradeId         Int?
  levelId         Int?
  unitId          Int?
  shiftMasterId   Int?
  shiftPlanId     Int?
  // Job details
  jobTitle        String?   @db.NVarChar(100)
  joinDate        DateTime
  confirmationDate DateTime?
  probationEndDate DateTime?
  // Versioning
  effectiveFrom   DateTime
  effectiveTo     DateTime?  // NULL = current

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee       @relation(fields: [employeeId], references: [id])
  department      Department     @relation(fields: [departmentId], references: [id])
  subDepartment   SubDepartment? @relation("SubDepartmentJobInfos", fields: [subDepartmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  designation     Designation    @relation(fields: [designationId], references: [id])
  employeeType    EmployeeType   @relation(fields: [employeeTypeId], references: [id])
  category        Category?      @relation(fields: [categoryId], references: [id])
  grade           Grade?         @relation(fields: [gradeId], references: [id])
  level           Level?         @relation(fields: [levelId], references: [id])
  unit            Unit?          @relation(fields: [unitId], references: [id])
  shiftMaster     ShiftMaster?   @relation(fields: [shiftMasterId], references: [id])
  shiftPlan       ShiftPlan?     @relation("ShiftPlanJobInfos", fields: [shiftPlanId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([employeeId])
  @@index([departmentId])
  @@index([designationId])
  @@index([effectiveFrom, effectiveTo])
  @@map("JobInfo")
}

// E4: SalaryStructure is versioned — effectiveFrom/effectiveTo.
//     Only one active record at a time. CTC breakdown fields.
model SalaryStructure {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  // CTC breakdown
  basic           Decimal   @db.Decimal(18, 2)
  hra             Decimal   @db.Decimal(18, 2)
  conveyanceAllowance Decimal @db.Decimal(18, 2) @default(0)
  medicalAllowance     Decimal @db.Decimal(18, 2) @default(0)
  specialAllowance     Decimal @db.Decimal(18, 2) @default(0)
  otherAllowance       Decimal @db.Decimal(18, 2) @default(0)
  // Statutory
  pfApplicable    Boolean   @default(true)
  esiApplicable   Boolean   @default(false)
  // Totals
  monthlyCtc      Decimal   @db.Decimal(18, 2)
  annualCtc       Decimal   @db.Decimal(18, 2)
  // Versioning
  effectiveFrom   DateTime
  effectiveTo     DateTime?  // NULL = current

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([effectiveFrom, effectiveTo])
  @@map("SalaryStructure")
}

// E9: Separate bank detail table — 1:1 for now, may extend to multiple.
model EmployeeBankDetail {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @unique
  bankName        String?   @db.NVarChar(100)
  branchName      String?   @db.NVarChar(100)
  accountNumber   String?   @db.NVarChar(30)
  ifscCode        String?   @db.NVarChar(20)
  accountType     String?   @db.NVarChar(20)  // savings | current | salary
  isPrimary       Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@map("EmployeeBankDetail")
}

// Dependents — 1:N with Employee
model EmployeeDependent {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  name            String    @db.NVarChar(100)
  relationship    String    @db.NVarChar(50)   // spouse | son | daughter | father | mother | other
  dateOfBirth     DateTime?
  isDependent     Boolean   @default(true)     // for insurance/tax purposes

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("EmployeeDependent")
}

// Previous work experience — 1:N with Employee
model EmployeeExperience {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  companyName     String    @db.NVarChar(100)
  designation     String    @db.NVarChar(100)
  fromDate        DateTime
  toDate          DateTime?  // NULL = current job
  reasonForLeaving String?  @db.NVarChar(500)
  lastDrawnSalary Decimal?  @db.Decimal(18, 2)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("EmployeeExperience")
}

// Education qualifications — 1:N with Employee
model EmployeeEducation {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  qualification   String    @db.NVarChar(100)   // e.g. "B.Tech", "MCA"
  institution     String?   @db.NVarChar(200)
  university      String?   @db.NVarChar(200)
  yearOfPassing   Int?
  percentage      Decimal?  @db.Decimal(5, 2)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("EmployeeEducation")
}

// E5: Documents with expiry tracking for Aadhaar/PAN/Passport/DL.
//     Also handles KPI/JD attachments via docType field (E6).
//     File upload is a placeholder stub — no actual file storage in this branch.
model EmployeeDocument {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  docType         String    @db.NVarChar(30)
  // "aadhaar" | "pan" | "passport" | "driving_license" | "kpi" | "jd" | "other"
  docNumber       String?   @db.NVarChar(50)    // e.g. Aadhaar number, PAN number
  fileName        String?   @db.NVarChar(200)   // placeholder — actual file path/URL later
  filePath        String?   @db.NVarChar(500)   // placeholder — actual file storage later
  // Expiry tracking
  issuedDate      DateTime?
  expiryDate      DateTime?                     // NULL = no expiry
  isVerified      Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([docType])
  @@index([expiryDate])
  @@map("EmployeeDocument")
}

// Asset allocation — join table between Employee and AssetMaster.
// Single-source-of-truth: no asset data duplicated on Employee.
// Read-only reference — actual asset management logic is a future phase.
model EmployeeAssetAllocation {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  assetMasterId   Int
  allocatedDate   DateTime  @default(now())
  returnedDate    DateTime?  // NULL = currently allocated
  notes           String?   @db.NVarChar(500)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee     @relation(fields: [employeeId], references: [id])
  assetMaster     AssetMaster  @relation(fields: [assetMasterId], references: [id])

  @@index([employeeId])
  @@index([assetMasterId])
  @@map("EmployeeAssetAllocation")
}

// E7: Exit interview — 1:1 with Employee, created on exit.
model ExitInterview {
  id              Int       @id @default(autoincrement())
  employeeId      Int       @unique
  exitDate        DateTime
  exitReason      String?   @db.NVarChar(500)
  exitType        String    @db.NVarChar(20)   // resignation | termination | retirement
  interviewNotes  String?   @db.NVarChar(2000)
  interviewDate   DateTime?
  interviewedBy   String?   @db.NVarChar(100)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id])

  @@map("ExitInterview")
}
