// ─────────────────────────────────────────────────────────────────────────────
// KUN HRMS — Prisma Schema
// Datasource: MS SQL Server (production)
// Branch: feature/prisma-base
//
// SCOPE: Base master/definition tables + soft-delete. No transactional logic.
// Do NOT add Attendance, Payroll, Performance, Training, Recruitment, Reports,
// Compliance, Leave/Loan/Asset logic, or ESS models here.
//
// OPEN QUESTIONS STATUS:
//   Q1. Grade & Level separate              → APPROVED
//   Q2. ESI/PF two tables                   → APPROVED
//   Q3. Site/Branch discriminator           → PENDING CLIENT CONFIRMATION (Site model commented out, will NOT migrate)
//   Q4. isActive + deletedAt                → APPROVED
//   Q5. Slab overlap prevention             → APPROVED: Option D (SQL Server trigger + app-layer validation)
//   Q6. SubDepartment → Department FK       → APPROVED
//   Q7. Int autoincrement                   → APPROVED
//   Q8. ShiftPlan override shape            → APPROVED (spec override fields before Phase 2)
//   Q9. OTPlan shape                        → APPROVED
//   Q10. DropdownMaster isActive             → ALREADY PRESENT (was a summary-table omission, not a schema gap)
//   Q11. Leave/Loan/Asset minimal fields    → APPROVED
//
// Q5 IMPLEMENTATION (Option D — approved):
//   DB-level overlap prevention via SQL Server AFTER INSERT/UPDATE triggers
//   on all 4 slab/rate tables (TDSSlab, ProfessionalTaxSlab, EsiRate, PfRate).
//   Trigger checks no overlapping (effectiveFrom, effectiveTo) ranges exist
//   for the same `code`, rolls back on conflict. App-layer validation in
//   service code provides clean error messages before hitting the DB.
//   Trigger SQL is in: prisma/triggers/slab_overlap_triggers.sql
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// 1. ORGANISATIONAL MASTER TABLES (soft-delete: isActive + deletedAt)
// ─────────────────────────────────────────────────────────────────────────────

model Department {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subDepartments SubDepartment[]
  employees      Employee[]

  @@map("Department")
}

model SubDepartment {
  id           Int       @id @default(autoincrement())
  departmentId Int
  code         String    @unique @db.NVarChar(20)
  name         String    @db.NVarChar(100)
  description  String?   @db.NVarChar(500)
  isActive     Boolean   @default(true)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department Department @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([departmentId])
  @@map("SubDepartment")
}

model Designation {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees Employee[]

  @@map("Designation")
}

model EmployeeType {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees Employee[]

  @@map("EmployeeType")
}

model Category {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees Employee[]

  @@map("Category")
}

