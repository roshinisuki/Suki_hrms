// ─────────────────────────────────────────────────────────────────────────────
// 6. AUTH + RBAC SKELETON
//    (feature/auth-rbac branch — included here so schema is complete)
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(20)
  name        String    @db.NVarChar(100)
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]

  @@map("Role")
}

model Permission {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.NVarChar(50) // e.g. "employee.view", "payroll.run"
  module      String    @db.NVarChar(50)         // top-level module, e.g. "employee"
  submodule   String?   @db.NVarChar(50)         // sub-module, e.g. "profile"
  page        String?   @db.NVarChar(50)         // page-level, e.g. "list"
  action      String    @db.NVarChar(20)         // "view" | "create" | "edit" | "delete" | "export"
  description String?   @db.NVarChar(500)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  rolePermissions RolePermission[]

  @@index([module, submodule, page])
  @@map("Permission")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("RolePermission")
}
